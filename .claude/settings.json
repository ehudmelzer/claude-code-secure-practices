{
  // ============================================================
  // Claude Code — Endpoint Security Settings
  // Place at: ~/.claude/settings.json  (global, all projects)
  //       or: <project>/.claude/settings.json  (project-scoped)
  //
  // HOW PERMISSIONS WORK — THREE TIERS:
  //
  //   "allow"  → auto-approved, Claude proceeds without asking
  //   (absent) → Claude asks for confirmation before proceeding
  //   "deny"   → HARD BLOCK, Claude cannot perform this action
  //              even if the user explicitly says "yes, do it"
  //
  // Strategy used here:
  //   - Low-risk read/inspect commands → allow (no friction)
  //   - Medium-risk commands (file writes, git commits, etc.)
  //     → not listed = Claude asks first (good default)
  //   - Irreversible / high-impact / exfiltration-risk commands
  //     → deny (no exceptions, ever)
  //
  // Deny is intentionally strict. If you find a legitimate use
  // for a denied command, grant it explicitly at the task level
  // rather than removing the deny rule.
  // ============================================================

  // ── TELEMETRY: OpenTelemetry (OTel) Configuration ─────────
  // Exports all Claude Code activity (tool calls, API requests,
  // permission decisions, costs, token usage) to your OTel
  // collector / SIEM. This gives your security team full
  // observability over what Claude does on every endpoint.
  //
  // REQUIRED: Set CLAUDE_CODE_ENABLE_TELEMETRY to "1" to activate.
  //
  // Replace the endpoint with your organization's OTel collector.
  // For authentication, set OTEL_EXPORTER_OTLP_HEADERS or use
  // the otelHeadersHelper for dynamic token refresh.
  //
  // PRIVACY NOTE:
  //   - User prompts are NOT logged by default. Set
  //     OTEL_LOG_USER_PROMPTS=1 to enable (privacy trade-off).
  //   - Tool arguments (bash commands, file paths) are NOT logged
  //     by default. Set OTEL_LOG_TOOL_DETAILS=1 to enable.
  // ──────────────────────────────────────────────────────────

  "env": {
    "CLAUDE_CODE_ENABLE_TELEMETRY": "1",
    "OTEL_METRICS_EXPORTER": "otlp",
    "OTEL_LOGS_EXPORTER": "otlp",
    "OTEL_EXPORTER_OTLP_PROTOCOL": "grpc",
    "OTEL_EXPORTER_OTLP_ENDPOINT": "http://YOUR_OTEL_COLLECTOR:4317",
    "OTEL_METRIC_EXPORT_INTERVAL": "60000",
    "OTEL_LOGS_EXPORT_INTERVAL": "5000"
    // ── Optional: Uncomment to log sensitive details ──
    // "OTEL_LOG_USER_PROMPTS": "1",
    // "OTEL_LOG_TOOL_DETAILS": "1"
    // ── Optional: Auth header for your collector ──
    // "OTEL_EXPORTER_OTLP_HEADERS": "Authorization=Bearer YOUR_TOKEN"
    // ── Optional: Tag sessions by team/department ──
    // "OTEL_RESOURCE_ATTRIBUTES": "department=engineering,team.id=platform"
  },

  // ── Optional: Dynamic OTel auth token refresh ─────────────
  // Point this to a script that outputs JSON with auth headers.
  // Claude Code will call it periodically (default: every 29 min).
  //
  // "otelHeadersHelper": "/path/to/generate_otel_headers.sh",

  // ── ACCOUNT RESTRICTION: SessionStart Hook ────────────────
  // Claude Code does not natively support account allowlists.
  // This hook runs at the start of every session and validates
  // the authenticated user's email against an allowed domain
  // pattern. Unauthorized sessions are killed immediately.
  //
  // TWO OPTIONS (uncomment one):
  //
  //   Option A — Email domain regex (recommended)
  //     Set ALLOWED_DOMAIN to a regex matching your corporate
  //     email domain(s). Examples:
  //       Single domain:    @yourcompany\.com$
  //       Multiple domains: @(yourcompany\.com|partner\.org)$
  //
  //   Option B — Account ID allowlist
  //     Set ALLOWED to a comma-separated list of Anthropic
  //     account IDs (no spaces).
  //
  // NOTE: This is a best-effort guardrail, not a hard boundary.
  // For true identity enforcement, use Anthropic's enterprise
  // SSO / domain capture features.
  // ──────────────────────────────────────────────────────────

  // "hooks": {
  //   "SessionStart": [
  //
  //     ── Option A: Email domain validation (recommended) ──
  //     {
  //       "type": "command",
  //       "command": "ALLOWED_DOMAIN='@yourcompany\\.com$' && EMAIL=$(claude auth status 2>&1 | grep -oE '[^ ]+@[^ ]+' | head -1) && echo \"$EMAIL\" | grep -qE \"$ALLOWED_DOMAIN\" || { echo '❌ Only corporate email accounts are allowed. Contact your admin.'; exit 1; }"
  //     }
  //
  //     ── Option B: Account ID allowlist ──
  //     {
  //       "type": "command",
  //       "command": "ALLOWED='acct_id_1,acct_id_2' && CURRENT=$(claude auth status 2>&1 | grep -oE '[a-f0-9-]{36}' | head -1) && echo \",$ALLOWED,\" | grep -q \",$CURRENT,\" || { echo '❌ Unauthorized account. Contact your admin.'; exit 1; }"
  //     }
  //
  //   ]
  // },

  "permissions": {

    // ── AUTO-APPROVED: Safe read-only / inspection commands ───
    // Claude will not ask before running these.
    "allow": [
      "Bash(git status)",
      "Bash(git log*)",
      "Bash(git diff*)",
      "Bash(git show*)",
      "Bash(git branch*)",
      "Bash(ls *)",
      "Bash(ls)",
      "Bash(cat *)",
      "Bash(echo *)",
      "Bash(pwd)",
      "Bash(whoami)",
      "Bash(which *)",
      "Bash(python* --version)",
      "Bash(node --version)",
      "Bash(npm list*)",
      "Bash(pip list*)"
    ],

    // ── NOTE: anything NOT listed above and NOT denied below ──
    // falls into the middle tier: Claude will ask for confirmation
    // before running it. This covers file writes, git commits,
    // npm install (local), running tests, starting servers, etc.
    // That's intentional — medium-risk = ask, don't block.

    // ── HARD BLOCKED: Never permitted under any circumstances ─
    // These cannot be unlocked by user confirmation in the chat.
    // To legitimately use one of these, run it yourself in terminal.
    "deny": [

      // ── Destructive filesystem ops ──
      "Bash(rm -rf *)",
      "Bash(rm -f *)",
      "Bash(shred *)",
      "Bash(mkfs*)",
      "Bash(dd *)",

      // ── Secrets reading ──
      // Prevents Claude from reading or printing credential files.
      // Note: "cat *" is in allow above, so these deny rules must
      // be more specific to override (deny takes precedence).
      "Bash(cat *id_rsa*)",
      "Bash(cat *id_ed25519*)",
      "Bash(cat *.pem)",
      "Bash(cat *.key)",
      "Bash(cat .env*)",
      "Bash(cat *credentials*)",
      "Bash(cat ~/.aws*)",
      "Bash(cat ~/.kube/config*)",
      "Bash(cat *.token)",
      "Bash(printenv *SECRET*)",
      "Bash(printenv *KEY*)",
      "Bash(printenv *TOKEN*)",
      "Bash(printenv *PASSWORD*)",

      // ── Exfiltration / piped execution ──
      // Prevents downloading-and-executing scripts and sending
      // file contents to external endpoints.
      "Bash(curl * | bash)",
      "Bash(curl * | sh)",
      "Bash(wget * | bash)",
      "Bash(wget * | sh)",
      "Bash(curl -d @*)",
      "Bash(curl --data @*)",
      "Bash(nc *)",
      "Bash(netcat *)",

      // ── Privilege escalation ──
      "Bash(sudo *)",
      "Bash(su *)",
      "Bash(chmod 777 *)",
      "Bash(doas *)",

      // ── Persistence mechanisms ──
      "Bash(crontab *)",
      "Bash(launchctl *)",
      "Bash(systemctl enable *)",
      "Bash(nohup * &)",

      // ── Cloud / infra mutations ──
      // Read-only cloud commands (aws s3 ls, kubectl get, etc.)
      // are NOT denied — they fall into the "ask" tier instead.
      // Only state-changing / destructive actions are hard-blocked.
      "Bash(terraform apply*)",
      "Bash(terraform destroy*)",
      "Bash(aws * delete*)",
      "Bash(aws * put-*)",
      "Bash(aws * create-*)",
      "Bash(aws * update-*)",
      "Bash(gcloud * delete*)",
      "Bash(gcloud * create*)",
      "Bash(kubectl delete *)",
      "Bash(kubectl apply *)",
      "Bash(kubectl exec *)",

      // ── Silent global package installation ──
      "Bash(apt-get install *)",
      "Bash(apt install *)",
      "Bash(brew install *)",
      "Bash(npm install -g *)",
      "Bash(pip install --break-system*)"
    ]
  }
}
